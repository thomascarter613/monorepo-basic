{
  "name": "monorepo-basic",
  "private": true,
  "type": "module",
  "packageManager": "bun",
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*",
    "tools/*"
  ],
  "scripts": {
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "check:style": "biome ci .",
    "check": "bun run lint && bun run check:style && bun run typecheck",
    "typecheck": "bun run --parallel --filter '*' typecheck && tsc --build --verbose"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.1",
    "@types/bun": "^1.3.14"
  },
  "peerDependencies": {
    "typescript": "^6.0.3"
  }
}
